# Environment configuration for Virtual Receptionist
# Copy this file to .env and fill in the values

# Server
PORT=3000

# Database (defaults to ./receptionist.db if not set)
# DB_PATH=./receptionist.db

# Twilio credentials (required for phone call handling)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# The public URL of this server (used by Twilio webhooks)
# e.g. https://yourapp.ngrok.io  or  https://yourapp.example.com
BASE_URL=https://your-public-url.example.com
